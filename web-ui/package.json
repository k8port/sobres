{
  "name": "web-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "test": "vitest --workspace vitest.workspace.ts --reporter=verbose --coverage",
    "test:run": "vitest run --workspace vitest.workspace.ts --reporter=verbose --coverage",
    "test:unit": "vitest run --workspace vitest.workspace.ts --reporter=verbose --project unit --coverage",
    "test:int": "vitest run --workspace vitest.workspace.ts --reporter=verbose --project integration --coverage",
    "test:e2e": "playwright test __tests__/e2e"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "next": "15.4.5",
    "postcss": "^8.5.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@playwright/test": "^1.57.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/formidable": "^3.4.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.28",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@types/testing-library__react": "^10.2.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "^9.39.2",
    "eslint-config-next": "15.1.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "formidable": "^3.5.4",
    "jsdom": "^26.1.0",
    "msw": "^2.12.7",
    "playwright": "^1.57.0",
    "pnpm": "10.26.2",
    "prettier": "^3.7.4",
    "supertest": "^7.2.2",
    "swr": "^2.3.8",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
