# ─────────────────────────────────────────────────────────────
# OS / Editor
# ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

.vscode/
.idea/
.cspell/

*.log

# ─────────────────────────────────────────────────────────────
# Secrets / env
# ─────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class

# Test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
nosetests.xml

# Type checkers / linters
.mypy_cache/
.dmypy.json
.ruff_cache/

# Packaging
dist/
*.egg-info/
.eggs/

# project tree output
**/project-tree.txt

# ─────────────────────────────────────────────────────────────
# Node / Next.js
# ─────────────────────────────────────────────────────────────
**/node_modules/
**/.pnp
.pnp.*
**/.yarn/*
!**/.yarn/patches
!**/.yarn/plugins
!**/.yarn/releases
!**/.yarn/versions

# Next build output
web-ui/.next/
web-ui/out/
web-ui/coverage/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# TypeScript build info
*.tsbuildinfo
web-ui/next-env.d.ts

# Vercel
.vercel/

# ─────────────────────────────────────────────────────────────
# Docker (ignore local overrides only)
# ─────────────────────────────────────────────────────────────
docker-compose.override.yml

# ─────────────────────────────────────────────────────────────
# Databases / local artifacts
# ─────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ─────────────────────────────────────────────────────────────
# Project-specific ignores (keep these scoped)
# ─────────────────────────────────────────────────────────────
web-ui/public/statements/

# Any statements directory anywhere in the project
**/statements/

# Any PDF document anywhere in the project
*.pdf

# Spreadsheet and CSV documents anywhere in the project
*.csv
*.xlsx
